{
	"compilerOptions": {
		"allowJs": false,
		"checkJs": false,
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2020",
		"types": [ "react", "react-dom" ]
	},
	"include": [ "src/admin/**/*" ]
}
